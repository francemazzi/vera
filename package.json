{
  "name": "vera",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.22.1 <23",
    "pnpm": ">=10.33.0 <11"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "clean": "pnpm -r --if-present clean",
    "generate": "pnpm -r --if-present generate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm generate && eslint . --max-warnings 0",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "pnpm -r --if-present test:unit",
    "test:integration": "pnpm -r --if-present test:integration",
    "test:contract": "pnpm -r --if-present test:contract",
    "test:e2e": "pnpm -r --if-present test:e2e",
    "test:coverage": "vitest run --coverage",
    "public-boundary:check": "pnpm --filter @vera/public-boundary scan",
    "security:check": "docker run --rm -v \"$PWD:/src:ro\" ghcr.io/google/osv-scanner:v2.4.0 scan source -L /src/pnpm-lock.yaml",
    "verify": "pnpm generate && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm test:contract && pnpm build && pnpm test:e2e && pnpm test:coverage && pnpm public-boundary:check"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "prisma": "7.8.0",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.13"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
