# Local runtime
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL and pgvector
POSTGRES_DB=vera
POSTGRES_USER=vera
POSTGRES_PASSWORD=local-only
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vera:local-only@127.0.0.1:5432/vera?schema=public

# Future API and web applications
API_HOST=127.0.0.1
API_PORT=3000
WEB_HOST=127.0.0.1
WEB_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:3000/v1

# OpenRouter is opt-in for existing technical demos. Never expose this key via VITE_*.
OPENROUTER_API_KEY=
VERA_OPENROUTER_LIVE=0
VERA_LABEL_RUNNER_OPENROUTER_LIVE=0

# Private SILTO-LABEL runner. In Cloud Run, OPENROUTER_API_KEY is injected from Secret Manager.
# It never falls back to Ollama or any local model.
LABEL_BACKEND_URL=
LABEL_BACKEND_AUDIENCE=
LABEL_RUNNER_AUDIENCE=
LABEL_TASKS_INVOKER_SERVICE_ACCOUNT_EMAIL=
LABEL_GCS_BUCKET=
LABEL_OPENROUTER_MODEL=
LABEL_PROMPT_VERSION=label-v1
LABEL_RULE_PACK_VERSION=
LABEL_SOURCE_SNAPSHOT=
LABEL_OPENROUTER_TIMEOUT_MS=60000
