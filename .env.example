# Local runtime
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL and pgvector
POSTGRES_DB=vera
POSTGRES_USER=vera
POSTGRES_PASSWORD=local-only
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vera:local-only@127.0.0.1:5432/vera?schema=public

# Future API and web applications
API_HOST=127.0.0.1
API_PORT=3000
WEB_HOST=127.0.0.1
WEB_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:3000/v1

# Ollama runs on the host. Use the Docker URL from containerized services.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DOCKER_BASE_URL=http://host.docker.internal:11434
