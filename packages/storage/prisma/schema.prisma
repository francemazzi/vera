generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model LocalAccount {
  id           String    @id @db.Uuid
  email        String    @unique
  displayName  String
  passwordHash String
  role         String
  disabled     Boolean   @default(false)
  createdAt    DateTime  @db.Timestamptz(6)
  sessions     Session[]

  @@map("local_accounts")
}

model Session {
  id        String    @id @db.Uuid
  tokenHash String    @unique
  accountId String    @db.Uuid
  account   LocalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime  @db.Timestamptz(6)
  expiresAt DateTime  @db.Timestamptz(6)
  revokedAt DateTime? @db.Timestamptz(6)

  @@index([accountId])
  @@index([expiresAt])
  @@map("sessions")
}

model EvaluationRunRecord {
  id               String                 @id @db.Uuid
  contentHash      String                 @unique
  aggregateOutcome String
  validationScope  String
  payload          Json
  createdAt        DateTime               @db.Timestamptz(6)
  reviewDecisions  ReviewDecisionRecord[]

  @@map("evaluation_runs")
}

model ReviewDecisionRecord {
  id                String              @id @db.Uuid
  runId             String              @db.Uuid
  run               EvaluationRunRecord @relation(fields: [runId], references: [id], onDelete: Cascade)
  sequence          Int
  contentHash       String              @unique
  previousEventHash String?
  actorId           String              @db.Uuid
  payload           Json
  createdAt         DateTime            @db.Timestamptz(6)

  @@unique([runId, sequence])
  @@index([runId])
  @@map("review_decisions")
}

model BlobObject {
  sha256     String   @id
  byteLength Int
  mediaType  String
  path        String
  createdAt   DateTime @db.Timestamptz(6)

  @@map("blob_objects")
}

model IdempotencyRecord {
  scope        String
  key          String
  requestHash  String?
  responseHash String
  response     Json
  createdAt    DateTime @db.Timestamptz(6)
  expiresAt    DateTime @db.Timestamptz(6)

  @@id([scope, key])
  @@index([expiresAt])
  @@map("idempotency_records")
}

/// Private SILTO-LABEL governance records. They deliberately live beside, but
/// do not widen, the public TECHNICAL_DEMO contract surface.
model PrivateLabelSource {
  id               String                      @id @db.Uuid
  stableReference  String                      @unique
  title            String
  jurisdiction     String
  createdAt        DateTime                    @db.Timestamptz(6)
  createdByActorId String                      @db.Uuid
  versions         PrivateLabelSourceVersion[]

  @@map("private_label_sources")
}

model PrivateLabelSourceVersion {
  id               String                         @id @db.Uuid
  sourceId         String                         @db.Uuid
  source           PrivateLabelSource             @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  revision         Int
  contentHash      String                         @unique
  contentObjectRef String
  createdAt        DateTime                       @db.Timestamptz(6)
  createdByActorId String                         @db.Uuid
  transitions      PrivateLabelSourceTransition[]

  @@unique([sourceId, revision])
  @@index([sourceId])
  @@map("private_label_source_versions")
}

model PrivateLabelSourceTransition {
  id              String                    @id @db.Uuid
  sourceVersionId String                    @db.Uuid
  sourceVersion   PrivateLabelSourceVersion @relation(fields: [sourceVersionId], references: [id], onDelete: Restrict)
  sequence        Int
  fromState       String?
  toState         String
  actorId         String                    @db.Uuid
  actorRole       String
  reason          String?
  contentHash     String                    @unique
  createdAt       DateTime                  @db.Timestamptz(6)

  @@unique([sourceVersionId, sequence])
  @@index([sourceVersionId])
  @@map("private_label_source_transitions")
}

model PrivateLabelRulePackVersion {
  id                 String                       @id @db.Uuid
  version            String                       @unique
  contentHash        String                       @unique
  sourceSnapshotHash String
  snapshot           Json
  createdAt          DateTime                     @db.Timestamptz(6)
  createdByActorId   String                       @db.Uuid
  activations        PrivateLabelRulePackActivation[]
  evaluationRuns     PrivateLabelEvaluationRun[]

  @@map("private_label_rule_pack_versions")
}

model PrivateLabelRulePackActivation {
  id                String                      @id @db.Uuid
  rulePackVersionId String                      @db.Uuid
  rulePackVersion   PrivateLabelRulePackVersion @relation(fields: [rulePackVersionId], references: [id], onDelete: Restrict)
  sequence          Int
  action            String
  countryCodes      String[]
  actorId           String                      @db.Uuid
  reason            String?
  previousEventHash String?
  contentHash       String                      @unique
  createdAt         DateTime                    @db.Timestamptz(6)

  @@unique([rulePackVersionId, sequence])
  @@index([rulePackVersionId])
  @@map("private_label_rule_pack_activations")
}

model PrivateLabelEvaluationRun {
  id                 String                      @id @db.Uuid
  externalAnalysisId String                      @db.Uuid
  inputSha256        String
  provider           String
  model              String
  promptVersion      String
  rulePackVersionId  String                      @db.Uuid
  rulePackVersion    PrivateLabelRulePackVersion @relation(fields: [rulePackVersionId], references: [id], onDelete: Restrict)
  sourceSnapshotHash String
  controls           Json
  evidenceRefs       Json
  contentHash        String                      @unique
  createdAt          DateTime                    @db.Timestamptz(6)

  @@index([externalAnalysisId])
  @@index([rulePackVersionId])
  @@map("private_label_evaluation_runs")
}

/// Public Phase 14 durable compliance-source aggregate (TECHNICAL_DEMO).
model ComplianceSourceRecord {
  id               String                         @id @db.Uuid
  type             String
  domain           String
  jurisdiction     String
  title            String
  stableReference  String
  validationScope  String
  payload          Json
  createdAt        DateTime                       @db.Timestamptz(6) @default(now())
  versions         ComplianceSourceVersionRecord[]

  @@index([domain, jurisdiction])
  @@map("compliance_sources")
}

model ComplianceSourceVersionRecord {
  id                 String                              @id @db.Uuid
  sourceId           String                              @db.Uuid
  source             ComplianceSourceRecord              @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  revision           Int
  contentHash        String                              @unique
  replacesVersionId  String?                             @db.Uuid
  payload            Json
  createdAt          DateTime                            @db.Timestamptz(6)
  transitions        ComplianceSourceTransitionRecord[]

  @@unique([sourceId, revision])
  @@index([sourceId])
  @@map("compliance_source_versions")
}

model ComplianceSourceTransitionRecord {
  id              String                        @id @db.Uuid
  versionId       String                        @db.Uuid
  version         ComplianceSourceVersionRecord @relation(fields: [versionId], references: [id], onDelete: Restrict)
  sequence        Int
  fromState       String?
  toState         String
  actorId         String                        @db.Uuid
  contentHash     String
  payload         Json
  createdAt       DateTime                      @db.Timestamptz(6)

  @@unique([versionId, sequence])
  @@index([versionId])
  @@map("compliance_source_transitions")
}

model RuleCardRecord {
  id               String                 @id @db.Uuid
  sourceId         String                 @db.Uuid
  sourceVersionId  String                 @db.Uuid
  sourceSection    String
  validationScope  String
  payload          Json
  createdAt        DateTime               @db.Timestamptz(6) @default(now())
  revisions        RuleCardRevisionRecord[]

  @@index([sourceId, sourceVersionId])
  @@map("rule_cards")
}

model RuleCardRevisionRecord {
  id          String                 @id @db.Uuid
  cardId      String                 @db.Uuid
  card        RuleCardRecord         @relation(fields: [cardId], references: [id], onDelete: Restrict)
  revision    Int
  contentHash String                 @unique
  payload     Json
  createdAt   DateTime               @db.Timestamptz(6)
  audit       RuleCardAuditRecord[]

  @@unique([cardId, revision])
  @@index([cardId])
  @@map("rule_card_revisions")
}

model RuleCardAuditRecord {
  id         String                 @id @db.Uuid
  revisionId String                 @db.Uuid
  revision   RuleCardRevisionRecord @relation(fields: [revisionId], references: [id], onDelete: Restrict)
  sequence   Int
  kind       String
  actorId    String                 @db.Uuid
  payload    Json
  createdAt  DateTime               @db.Timestamptz(6)

  @@unique([revisionId, sequence])
  @@index([revisionId])
  @@map("rule_card_audit")
}

model RulePackDraftRecord {
  id          String   @id @db.Uuid
  packId      String   @db.Uuid
  revision    Int
  contentHash String
  payload     Json
  updatedAt   DateTime @db.Timestamptz(6)
  createdAt   DateTime @db.Timestamptz(6) @default(now())

  @@index([packId])
  @@map("rule_pack_drafts")
}

model RulePackDraftContributorRecord {
  draftId String @db.Uuid
  actorId String @db.Uuid

  @@id([draftId, actorId])
  @@index([draftId])
  @@map("rule_pack_draft_contributors")
}

model RulePackVersionRecord {
  id          String   @id @db.Uuid
  packId      String   @db.Uuid
  semver      String
  contentHash String   @unique
  payload     Json
  publishedAt DateTime @db.Timestamptz(6)
  createdAt   DateTime @db.Timestamptz(6) @default(now())

  @@unique([packId, semver])
  @@index([packId])
  @@map("rule_pack_versions")
}

model RulePackVersionExcludedActivatorRecord {
  versionId String @db.Uuid
  actorId   String @db.Uuid

  @@id([versionId, actorId])
  @@index([versionId])
  @@map("rule_pack_version_excluded_activators")
}

model RulePackDraftPublicationRecord {
  draftId           String @id @db.Uuid
  publishedVersionId String @db.Uuid @unique

  @@map("rule_pack_draft_publications")
}

model ActivationEventRecord {
  id                String   @id @db.Uuid
  packId            String   @db.Uuid
  sequence          Int
  type              String
  versionId         String   @db.Uuid
  contentHash       String   @unique
  previousEventHash String?
  payload           Json
  recordedAt        DateTime @db.Timestamptz(6)

  @@unique([packId, sequence])
  @@index([packId])
  @@map("activation_events")
}

model RuleTestRunRecord {
  id                      String   @id @db.Uuid
  requestId               String   @unique
  rulePackVersionId       String   @db.Uuid
  rulePackVersionContentHash String
  contentHash             String   @unique
  passed                  Boolean
  validationScope         String
  payload                 Json
  createdAt               DateTime @db.Timestamptz(6) @default(now())

  @@index([rulePackVersionId])
  @@map("rule_test_runs")
}

model RulePackImpactReportRecord {
  id               String   @id @db.Uuid
  contentHash      String   @unique
  validationScope  String
  payload          Json
  createdAt        DateTime @db.Timestamptz(6) @default(now())

  @@map("rule_pack_impact_reports")
}
