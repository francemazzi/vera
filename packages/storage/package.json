{
  "name": "@vera/storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate --config prisma.config.ts",
    "migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "build": "pnpm generate && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist src/generated",
    "typecheck": "pnpm generate && tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run test/unit",
    "test:integration": "pnpm generate && vitest run test/integration"
  },
  "dependencies": {
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "@vera/contracts": "workspace:*",
    "@vera/rules-core": "workspace:*",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "prisma": "catalog:",
    "testcontainers": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
